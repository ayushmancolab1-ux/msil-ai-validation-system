# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# Virtual environment
venv/
.venv/
env/
ENV/

# ── Environment / secrets — NEVER commit real keys ───────────────────────────
backend/.env
.env
.env.local
.env.*.local

# ── Database ──────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Uploaded files (user uploads, not code) ──────────────────────────────────
backend/uploads/drawings/*
backend/uploads/wis/*
# Keep the directory structure but not the files
!backend/uploads/drawings/.gitkeep
!backend/uploads/wis/.gitkeep

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/
*.log
npm-debug.log*

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
